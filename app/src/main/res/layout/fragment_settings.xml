<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/profile_header"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_gradient"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_profile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="8dp"
            app:strokeWidth="4dp"
            app:strokeColor="?attr/colorSurface"
            app:layout_constraintBottom_toBottomOf="@id/profile_header"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile_header">

            <ImageView
                android:id="@+id/image_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="28dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Profile Picture" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_change_photo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Photo"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconTint="?attr/colorOnSurface"
            app:iconSize="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_profile" />

        <TextView
            android:id="@+id/text_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:text="Username"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_change_photo" />

        <TextView
            android:id="@+id/text_profile_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="Security Specialist Member"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_profile_name" />

        <!-- Quick Emergency Access -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_panic_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:text="EMERGENCY PANIC BUTTON"
            android:textColor="@color/white"
            app:backgroundTint="@color/risk_high"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_dialog_alert"
            app:iconPadding="12dp"
            app:iconSize="24dp"
            app:iconTint="@color/white"
            app:layout_constraintTop_toBottomOf="@id/text_profile_status" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_appearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/btn_panic_button">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_theme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="center"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_light_mode"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Light"
                        app:icon="@android:drawable/ic_menu_day" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_dark_mode"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark"
                        app:icon="@android:drawable/ic_menu_recent_history" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_system_mode"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System"
                        app:icon="@android:drawable/ic_menu_manage" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_security_tools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/card_appearance">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Advanced Security Tools"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_data_breach"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="start|center_vertical"
                    android:text="Data Breach Checker"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_search" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_qr_scan"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="Secure QR Scanner"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_camera" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_wifi_audit"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="Wi-Fi Security Auditor"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_mylocation" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_password_check"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="Check Password Strength"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_lock_lock" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_app_audit"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="App Security Audit"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_dialog_info" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_education"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/card_security_tools">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learning &amp; Updates"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"
                    android:textColor="?attr/colorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_2fa_guide"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="start|center_vertical"
                    android:text="2FA Setup Guide"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_info_details" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cyber_news"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="Latest Cyber Security News"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_agenda" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_quiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Take Security Quiz"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_education">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_report_crime"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="Report to Cyber Crime Cell"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_report_image" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_account_settings"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="start|center_vertical"
                    android:text="Account Settings"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_manage" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_logout"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="start|center_vertical"
                    android:text="Logout from CyberGuard"
                    android:textColor="@color/risk_high"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconTint="@color/risk_high" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
