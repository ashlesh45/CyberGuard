<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_login">

    <fragment
        android:id="@+id/navigation_login"
        android:name="com.example.cyberguard.presentation.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_knowledge"
            app:destination="@id/navigation_knowledge"
            app:popUpTo="@id/navigation_login"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_knowledge"
        android:name="com.example.cyberguard.presentation.ui.KnowledgeFragment"
        android:label="Knowledge Base"
        tools:layout="@layout/fragment_knowledge" />

    <fragment
        android:id="@+id/navigation_advisories"
        android:name="com.example.cyberguard.presentation.ui.AdvisoriesFragment"
        android:label="Cyber Advisories"
        tools:layout="@layout/fragment_advisories" />

    <fragment
        android:id="@+id/navigation_triage"
        android:name="com.example.cyberguard.presentation.ui.TriageFragment"
        android:label="Incident Triage"
        tools:layout="@layout/fragment_triage" />

    <fragment
        android:id="@+id/navigation_scam"
        android:name="com.example.cyberguard.presentation.ui.ScamFragment"
        android:label="Scam Detector"
        tools:layout="@layout/fragment_scam" />

    <fragment
        android:id="@+id/navigation_community"
        android:name="com.example.cyberguard.presentation.ui.CommunityFragment"
        android:label="Community"
        tools:layout="@layout/fragment_community" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.cyberguard.presentation.ui.SettingsFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_account"
            app:destination="@id/navigation_account_settings" />
        <action
            android:id="@+id/action_settings_to_quiz"
            app:destination="@id/navigation_quiz" />
        <action
            android:id="@+id/action_settings_to_audit"
            app:destination="@id/navigation_app_audit" />
        <action
            android:id="@+id/action_settings_to_data_breach"
            app:destination="@id/navigation_data_breach" />
        <action
            android:id="@+id/action_settings_to_qr_scanner"
            app:destination="@id/navigation_qr_scanner" />
        <action
            android:id="@+id/action_settings_to_wifi_auditor"
            app:destination="@id/navigation_wifi_auditor" />
        <action
            android:id="@+id/action_settings_to_2fa_guide"
            app:destination="@id/navigation_2fa_guide" />
        <action
            android:id="@+id/action_settings_to_note_vault"
            app:destination="@id/navigation_note_vault" />
        <action
            android:id="@+id/action_settings_to_insurance_guide"
            app:destination="@id/navigation_insurance_guide" />
        <action
            android:id="@+id/action_settings_to_permission_shame"
            app:destination="@id/navigation_permission_shame" />
    </fragment>

    <fragment
        android:id="@+id/navigation_data_breach"
        android:name="com.example.cyberguard.presentation.ui.DataBreachFragment"
        android:label="Data Breach Checker"
        tools:layout="@layout/fragment_data_breach" />

    <fragment
        android:id="@+id/navigation_qr_scanner"
        android:name="com.example.cyberguard.presentation.ui.QrScannerFragment"
        android:label="Secure QR Scanner"
        tools:layout="@layout/fragment_qr_scanner" />

    <fragment
        android:id="@+id/navigation_wifi_auditor"
        android:name="com.example.cyberguard.presentation.ui.WifiAuditorFragment"
        android:label="Wi-Fi Security Auditor"
        tools:layout="@layout/fragment_wifi_auditor" />

    <fragment
        android:id="@+id/navigation_2fa_guide"
        android:name="com.example.cyberguard.presentation.ui.TwoFactorGuideFragment"
        android:label="2FA Setup Guide"
        tools:layout="@layout/fragment_two_factor_guide" />

    <fragment
        android:id="@+id/navigation_note_vault"
        android:name="com.example.cyberguard.presentation.ui.NoteVaultFragment"
        android:label="Secure Note Vault"
        tools:layout="@layout/fragment_note_vault" />

    <fragment
        android:id="@+id/navigation_insurance_guide"
        android:name="com.example.cyberguard.presentation.ui.InsuranceGuideFragment"
        android:label="Cyber Insurance Guide"
        tools:layout="@layout/fragment_insurance_guide" />

    <fragment
        android:id="@+id/navigation_permission_shame"
        android:name="com.example.cyberguard.presentation.ui.PermissionShameFragment"
        android:label="Permission Wall of Shame"
        tools:layout="@layout/fragment_permission_shame" />

    <fragment
        android:id="@+id/navigation_account_settings"
        android:name="com.example.cyberguard.presentation.ui.AccountSettingsFragment"
        android:label="Account Settings"
        tools:layout="@layout/fragment_account_settings" />

    <fragment
        android:id="@+id/navigation_quiz"
        android:name="com.example.cyberguard.presentation.ui.QuizFragment"
        android:label="Security Quiz"
        tools:layout="@layout/fragment_quiz">
        <action
            android:id="@+id/action_quiz_to_explanation"
            app:destination="@id/navigation_quiz_explanation" />
    </fragment>

    <fragment
        android:id="@+id/navigation_quiz_explanation"
        android:name="com.example.cyberguard.presentation.ui.QuizExplanationFragment"
        android:label="Explanation"
        tools:layout="@layout/fragment_quiz_explanation">
        <argument
            android:name="correctAnswer"
            app:argType="string" />
        <argument
            android:name="explanation"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_app_audit"
        android:name="com.example.cyberguard.presentation.ui.AppAuditFragment"
        android:label="App Security Audit"
        tools:layout="@layout/fragment_app_audit" />

    <fragment
        android:id="@+id/navigation_fraud_detail"
        android:name="com.example.cyberguard.presentation.ui.FraudDetailFragment"
        android:label="Fraud Details"
        tools:layout="@layout/fragment_fraud_detail">
        <argument
            android:name="fraudId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/navigation_advisory_detail"
        android:name="com.example.cyberguard.presentation.ui.AdvisoryDetailFragment"
        android:label="Advisory Details"
        tools:layout="@layout/fragment_advisory_detail">
        <argument
            android:name="advisoryId"
            app:argType="string" />
    </fragment>

    <action
        android:id="@+id/action_global_login"
        app:destination="@id/navigation_login"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />
</navigation>